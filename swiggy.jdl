entity Restaurant {
    name String required
    cuisine String
    rating Double
    location String
}

entity DeliveryZone {
    name String required
    active Boolean required
    boundary String
}

entity DeliveryPartner {
    name String required
    status PartnerStatus required
    location String
}

entity FoodOrder {
    customerName String required
    deliveryAddress String required
    deliveryLocation String
    status OrderStatus required
}

enum PartnerStatus {
    AVAILABLE, BUSY, OFFLINE
}

enum OrderStatus {
    PENDING, ASSIGNED, DELIVERED
}

relationship ManyToOne {
    FoodOrder{restaurant} to Restaurant
    FoodOrder{deliveryPartner} to DeliveryPartner
}

paginate Restaurant, FoodOrder with pagination
service all with serviceImpl
dto all with mapstruct
