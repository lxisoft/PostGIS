<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity DeliveryRequest.
        Includes delivery_location geography(Point,4326) column for PostGIS spatial queries.
    -->
    <changeSet id="20260605200251-1" author="jhipster">
        <createTable tableName="delivery_request">
            <column name="id" type="bigint" autoIncrement="true" startWith="1500">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="request_date" type="${datetimeType}">
                <constraints nullable="false" />
            </column>
            <column name="status" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="customer_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="delivery_request" columnName="request_date" columnDataType="${datetimeType}"/>
    </changeSet>

    <!-- Add PostGIS delivery_location column + GiST spatial index to delivery_request table -->
    <changeSet id="20260605200251-2-delivery-location" author="geodelivery-agent">
        <sql>
            ALTER TABLE delivery_request
            ADD COLUMN IF NOT EXISTS delivery_location geography(Point,4326);
        </sql>
        <sql>
            CREATE INDEX IF NOT EXISTS idx_delivery_request_location
            ON delivery_request USING GIST(delivery_location);
        </sql>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->

    <!--
        Load sample data generated with Faker.js
        - This data can be easily edited using a CSV editor (or even MS Excel) and
          is located in the 'src/main/resources/config/liquibase/fake-data' directory
        - By default this data is applied when running with the JHipster 'dev' profile.
    -->
    <changeSet id="20260605200251-1-data" author="jhipster" context="faker">
        <loadData
                  file="config/liquibase/fake-data/delivery_request.csv"
                  separator=";"
                  tableName="delivery_request"
                  usePreparedStatements="true">
            <column name="id" type="numeric"/>
            <column name="request_date" type="date"/>
            <column name="status" type="string"/>
            <!-- jhipster-needle-liquibase-add-loadcolumn - JHipster (and/or extensions) can add load columns here -->
        </loadData>
    </changeSet>

</databaseChangeLog>
